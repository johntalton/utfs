{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
  "files": {
		"ignoreUnknown": false,
    "includes": [ "src/**/*" ]
	},
  "linter": {
		"enabled": true,
    "domains": {
      "qwik": "none",
      "project": "all",
      "types": "all"
    },
		"rules": {
      "preset":"all",

      "a11y": "error",
      "performance": "error",
      "security": "error",

      "complexity": {
        "preset":"all",
        "recommended": true,

        "noExcessiveCognitiveComplexity": "warn",
        "noExcessiveLinesPerFunction":"warn",
        "noStaticOnlyClass": "off",
        "useLiteralKeys": "warn",
				"noUselessUndefined":"warn",
				"useMaxParams":"warn",


        "noExcessiveNestedTestSuites":"error",
        "noForEach": "error",
        "noImplicitCoercions":"error",
        "noUselessCatchBinding":"error",
        "noUselessStringConcat":"error",
        "noVoid":"error",
        "useWhile":"error",
        "useSimplifiedLogicExpression":"error",


        "noDivRegex":"error",
        "noImportantStyles":"error",
        "noRedundantDefaultExport":"error",
        "noUselessReturn":"error",
        "useArrayFind":"error"

      },
      "correctness": {
        "preset": "all",
        "recommended": true,

        "noNodejsModules":"off",
        "useParseIntRadix":"error",
        "noUnresolvedImports":"error",
        "noProcessGlobal":"error",


        "noGlobalDirnameFilename":"error",
        "noUndeclaredDependencies":"error",
        "noUndeclaredVariables":"error",
        "useImportExtensions":"error",
        "useJsonImportAttributes":"error",


        "noBeforeInteractiveScriptOutsideDocument":"error",
        "noDuplicateArgumentNames":"error",
        "noDuplicateAttributes":"error",
        "noDuplicateEnumValueNames":"error",
        "noDuplicateInputFieldNames":"error",
        "noDuplicateVariableNames":"error",
        "noInvalidDirectionInLinearGradient":"error",
        "noInvalidPositionAtImportRule":"error",
        "noMissingVarFunction":"error",
        "noUnknownFunction":"error",
        "noUnknownMediaFeatureName":"error",
        "noUnknownProperty":"error",
        "noUnknownPseudoClass":"error",
        "noUnknownPseudoElement":"error",
        "noUnknownTypeSelector":"error",
        "noUnknownUnit":"error",
        "noUnmatchableAnbSelector":"error",
        "noUnusedInstantiation":"error",
        "useInlineScriptId":"error",
        "useLoneAnonymousOperation":"error"
      },
      "suspicious": {
        "recommended": true,
        "preset":"all",

        "noConsole":"off",
        "useAwait":"off",
        "noBitwiseOperators":"error",
        "noUnnecessaryConditions":"off",


        "noConstantBinaryExpressions":"error",
        "noDeprecatedImports":"error",
        "noEmptyBlockStatements":"error",
        "noEmptySource":"error",
        "noEvolvingTypes":"error",
        "noImportCycles":"error",
        "noMisplacedAssertion":"error",
        "noSkippedTests":"error",
        "noUnassignedVariables":"error",
        "noUnusedExpressions":"error",
        "noVar":"error",
        "useErrorMessage":"error",
        "useGuardForIn":"error",
        "useNumberToFixedDigitsArgument": "error",
        "useStaticResponseMethods":"error",
        "useStrictMode":"error",


        "noAssignInExpressions":"error",
        "noBiomeFirstException":"error",
        "noDeprecatedMediaType":"error",
        "noDuplicateAtImportRules":"error",
        "noDuplicateCustomProperties":"error",
        "noDuplicateDependencies":"error",
        "noDuplicatedSpreadProps":"error",
        "noDuplicateEnumValues":"error",
        "noDuplicateFields":"error",
        "noDuplicateFontNames":"error",
        "noDuplicateGraphqlOperationName":"error",
        "noDuplicateProperties":"error",
        "noDuplicateSelectorsKeyframeBlock":"error",
        "noEmptyBlock":"error",
        "noEqualsToNull":"error",
        "noForIn":"error",
        "noImplicitAnyLet":"error",
        "noImportantInKeyframe":"error",
        "noLeakedRender":"error",
        "noNestedPromises":"error",
        "noParametersOnlyUsedInRecursion":"error",
        "noProto":"error",
        "noQuickfixBiome":"error",
        "noReturnAssign":"error",
        "noShadow":"error",
        "noShorthandPropertyOverrides":"error",
        "noUndeclaredEnvVars":"error",
        "noUnknownAtRules":"error",
        "noUnknownAttribute":"error",
        "useArraySortCompare":"error",
        "useBiomeIgnoreFolder":"error",
        "useDeprecatedDate":"error",
        "useRequiredScripts":"error"
      },
      "style": {
        "preset": "all",
        "recommended": true,

        "useNamingConvention": "off",
        "noTernary":"off",
        "noProcessEnv": "error",
        "noMagicNumbers": "off",
        "noExcessiveClassesPerFile":"off",
        "noContinue":"off",
        "useExponentiationOperator":"off",
        "noNestedTernary": "error",


        "noCommonJs": "error",
        "noDefaultExport": "error",
        "noDoneCallback": "error",
        "noEnum": "error",
        "noExportedImports": "error",
        "noInferrableTypes": "error",
        "noJsxLiterals":"error",
        "noNamespace":"error",
        "noNegationElse": "error",
        "noParameterAssign": "error",
        "noParameterProperties": "error",
        "noRestrictedGlobals": "error",
        "noRestrictedImports": "error",
        "noRestrictedTypes": "error",
        "noShoutyConstants": "error",
        "noSubstr": "error",
        "noUnusedTemplateLiteral": "error",
        "noUselessElse": "error",
        "noYodaExpression": "error",
        "useAsConstAssertion": "error",
        "useAtIndex": "error",
        "useBlockStatements": "error",
        "useCollapsedElseIf": "error",
        "useCollapsedIf": "error",
        "useConsistentArrayType": "error",
        "useConsistentArrowReturn": "error",
        "useConsistentBuiltinInstantiation": "error",
        "useConsistentCurlyBraces": "error",
        "useConsistentMemberAccessibility": "error",
        "useConsistentObjectDefinitions": "error",
        "useConsistentTypeDefinitions": "error",
        "useDefaultParameterLast": "error",
        "useDefaultSwitchClause": "error",
        "useEnumInitializers": "error",
        "useExplicitLengthCheck": "error",
        "useExportsLast": "error",
        "useFilenamingConvention": "error",
        "useForOf": "error",
        "useFragmentSyntax": "error",
        "useGroupedAccessorPairs": "error",
        "useNodeAssertStrict": "error",
        "useNodejsImportProtocol":"error",
        "useNumberNamespace": "error",
        "useNumericSeparators": "error",
        "useObjectSpread": "error",
        "useReadonlyClassProperties": "error",
        "useShorthandAssign": "error",
        "useSingleVarDeclarator": "error",
        "useSymbolDescription": "error",
        "useThrowNewError": "error",
        "useThrowOnlyError": "error",
        "useTrimStartEnd": "error",
        "useUnifiedTypeSignatures": "error",


        "noDescendingSpecificity":"error",
        "noExcessiveLinesPerFile":"error",
        "noHexColors":"error",
        "noIncrementDecrement":"error",
        "noMultiAssign":"error",
        "noMultilineString":"error",
        "noRootType":"error",
        "noValueAtRule":"error",
        "useConsistentEnumValueType":"error",
        "useConsistentGraphqlDescriptions":"error",
        "useConsistentMethodSignatures":"error",
        "useDeprecatedReason":"error",
        "useDestructuring":"error",
        "useErrorCause":"error",
        "useGlobalThis":"error",
        "useInputName":"error",
        "useLoneExecutableDefinition":"error",
        "useSpreadOverApply":"error"
      },
      "nursery": {
        "preset":"all",
        "recommended": true,

        "noBaseToString":"warn",


        "noFloatingPromises": "error",
        "noMisusedPromises": "error",
        "useAwaitThenable": "error",
        "useExhaustiveSwitchCases": "error",
        "useExplicitType": "error",
        "useRegexpExec": "error",
        "useSortedClasses": "error",
        "noComponentHookFactories":"error",
        "noConditionalExpect":"error",
        "noDrizzleDeleteWithoutWhere":"error",
        "noDrizzleUpdateWithoutWhere":"error",
        "noDuplicateFieldDefinitionNames":"error",
        "noDuplicateSelectors":"error",
        "noEmptyObjectKeys":"error",
        "noExcessiveNestedCallbacks":"error",
        "noExcessiveSelectorClasses":"error",
        "noIdenticalTestTitle":"error",
        "noImpliedEval":"error",
        "noInlineStyles":"error",
        "noJsxLeakedDollar":"error",
        "noJsxNamespace":"error",
        "noLoopFunc":"error",
        "noMisleadingReturnType":"error",
        "noPlaywrightElementHandle":"error",
        "noPlaywrightEval":"error",
        "noTopLevelLiterals":"error",
        "noRestrictedDependencies":"error",
        "noUndeclaredClasses":"error",
        "noUnnecessaryTemplateExpression":"error",
        "useReduceTypeParameter":"error",
        "useRegexpTest":"error",
        "useScopedStyles":"error",
        "useStringStartsEndsWith":"error",
        "useTestHooksInOrder":"error",
        "useTestHooksOnTop":"error",
        "useThisInClassMethods":"error",
        "useUnicodeRegex":"error",
        "useVarsOnTop":"error",
        "useNamedCaptureGroup":"error",
        "noUnsafePlusOperands":"error",
        "noUntrustedLicenses":"error",
        "noUselessTypeConversion":"error",
        "noUnusedClasses":"error",
        "useArraySome":"error",
        "useBaseline":"error",
        "useConsistentTestIt":"error",
        "useDisposables":"error",
        "useDomNodeTextContent":"error",
        "useExpect":"error",
        "useExplicitReturnType":"error",
        "useIframeSandbox":"error",
        "useImportsFirst":"error",
        "useIncludes":"error",
        "useMathMinMax":"error",
        "useNullishCoalescing":"error"
      }
    }
  },
  "formatter": {
		"enabled": false,
		"indentStyle": "tab"
	},
  "javascript": {
    "formatter": {
      "semicolons": "asNeeded",
      "quoteStyle": "single"
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
